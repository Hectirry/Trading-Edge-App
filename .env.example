# Trading-Edge-App — environment template
# Real values live in /etc/trading-system/secrets.env (chmod 600, root owner) on VPS.
# docker-compose loads that file via `env_file:`. This .env.example is for dev reference only.

TRADING_ENV=staging
TEA_HOSTNAME=187-124-130-221.nip.io
TEA_LE_EMAIL=habuenahora@gmail.com

# Postgres
TEA_PG_HOST=tea-postgres
TEA_PG_PORT=5432
TEA_PG_DB=trading_edge
TEA_PG_USER=tea
TEA_PG_PASSWORD=CHANGE_ME

# Grafana
TEA_GF_ADMIN_USER=admin
TEA_GF_ADMIN_PASSWORD=CHANGE_ME
TEA_GF_ROOT_URL=https://187-124-130-221.nip.io/grafana/

# Redis
TEA_REDIS_HOST=tea-redis
TEA_REDIS_PORT=6379

# Internal control plane
TEA_API_TOKEN=CHANGE_ME
TEA_API_BASE_URL=http://tea-api:8000
TEA_DOCKER_SOCKET_PATH=/var/run/docker.sock
TEA_DOCKER_RESTART_ENABLED=false
TEA_RESTART_SERVICE_MAP=api=tea-api,engine=tea-engine,telegram=tea-telegram-bot,postgres=tea-postgres,redis=tea-redis,grafana=tea-grafana,ingestor=tea-ingestor

# Telegram bot control/alerts
TEA_TELEGRAM_BOT_TOKEN=
TEA_TELEGRAM_CHAT_ID=
TEA_TELEGRAM_AUTHORIZED_USERS=
TEA_OBSERVABILITY_LOOP_ENABLED=false
TEA_OBSERVABILITY_INTERVAL_S=900
TEA_OBSERVABILITY_PNL_ALERT_THRESHOLD=-100
TEA_OBSERVABILITY_STALE_TRADE_MINUTES=120

# Backups (Backblaze B2, S3-compatible)
TEA_B2_ENDPOINT=
TEA_B2_BUCKET=
TEA_B2_KEY_ID=
TEA_B2_APPLICATION_KEY=
TEA_BACKUP_LOCAL_DIR=/var/backups/tea

# Brokers — public endpoints work without keys; add read-only keys if rate limits bite.
TEA_BINANCE_API_KEY=
TEA_BINANCE_API_SECRET=
TEA_BYBIT_API_KEY=
TEA_BYBIT_API_SECRET=

# Polymarket sources
TEA_POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
TEA_POLYMARKET_DATA_API=https://data-api.polymarket.com
TEA_POLYMARKET_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market

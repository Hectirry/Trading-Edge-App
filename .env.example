# Trading-Edge-App — example env file.
# Copy to `.env` and fill in real values, OR symlink `.env` to a managed
# secrets file (the VPS uses `/etc/trading-system/secrets.env`).
#
# Names mirror `src/trading/common/config.py` (TEA_-prefixed vars are
# loaded by pydantic-settings; the rest are read directly via os.environ
# or by docker-compose).

# --- Core ---
# Two vars on purpose: `engine/node.py` reads bare TRADING_ENV directly as a
# live-mode safety guard, while pydantic Settings reads TEA_TRADING_ENV
# (env_prefix="TEA_") and exposes it as `settings.trading_env`. Set both
# so paper_engine + ingestor don't silently fall back to the "staging"
# default while the engine sees "dev".
TRADING_ENV=dev
TEA_TRADING_ENV=dev
TEA_HOSTNAME=localhost

# --- TLS (Traefik) ---
TEA_LE_EMAIL=you@example.com

# --- Postgres (also consumed by docker-compose) ---
TEA_PG_HOST=tea-postgres
TEA_PG_PORT=5432
TEA_PG_DB=trading_edge
TEA_PG_USER=tea
TEA_PG_PASSWORD=changeme

# --- Redis ---
TEA_REDIS_HOST=tea-redis
TEA_REDIS_PORT=6379

# --- Grafana ---
TEA_GF_ADMIN_USER=admin
TEA_GF_ADMIN_PASSWORD=changeme
TEA_GF_ROOT_URL=https://localhost/grafana

# --- Backups (Backblaze B2, optional) ---
TEA_BACKUP_LOCAL_DIR=/var/backups/trading
TEA_B2_KEY_ID=
TEA_B2_APPLICATION_KEY=
TEA_B2_ENDPOINT=
TEA_B2_BUCKET=

# --- Brokers (read-only public endpoints work without keys) ---
TEA_BINANCE_API_KEY=
TEA_BINANCE_API_SECRET=
TEA_BYBIT_API_KEY=
TEA_BYBIT_API_SECRET=

# --- Polymarket ---
TEA_POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
TEA_POLYMARKET_DATA_API=https://data-api.polymarket.com
TEA_POLYMARKET_CLOB_WS=wss://ws-subscriptions-clob.polymarket.com/ws/market

# --- Telegram (Phase 3) ---
TEA_TELEGRAM_BOT_TOKEN=
TEA_TELEGRAM_CHAT_ID=
TEA_TELEGRAM_AUTHORIZED_USERS=

# --- API (Phase 4) ---
TEA_API_TOKEN=

# --- LLM (OpenRouter) ---
OPENROUTER_API_KEY=

# --- Oracle + liquidations (ADR 0012) ---
# Free Polygon RPC (Alchemy). Format: https://polygon-mainnet.g.alchemy.com/v2/<KEY>
ALCHEMY_POLYGON_URL=
# Coinalyze API key (free tier: 40 req/min). https://coinalyze.net
COINALYZE_API_KEY=
